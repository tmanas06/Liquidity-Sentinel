API_PORT=4020
NETWORK=avalanche-fuji

# Use mock for local demos. Use fuji to verify a real Fuji ERC-20 transfer tx hash.
PAYMENT_MODE=mock
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
API_BASE_URL=http://localhost:4020
AGENT_ID=1

# Required only for PAYMENT_MODE=fuji. Use a funded test wallet only.
AGENT_PRIVATE_KEY=

# Fuji deployment used by this demo. Verify addresses before using another network.
USDC_FUJI_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
SENTINEL_VAULT_ADDRESS=0x715F47Ce330aF0fd7130290874a182FBaF1D892F
MOCK_VAULT_ADDRESS=0xd9cFAad4e9ad195e08ec894e54Fc4462590549F0

LOW_TIER_AMOUNT=10000
HIGH_TIER_AMOUNT=500000
TOKEN_DECIMALS=6
INVOICE_TTL_SECONDS=300
MOCK_REPUTATION_SCORE=95
REPUTATION_MODE=mock
MID_TIER_AMOUNT=100000
SENTINEL_PRIVATE_KEY=
REPUTATION_REGISTRY_ADDRESS=0xa0C727A89D97eea9368b758E77Db1ab6baDe373F
IDENTITY_REGISTRY_ADDRESS=0xf103838D5d0AE522198E162dA4732948d5c0a24f

# The CLI agent auto-approves in off/mock mode. live requires GROQ_API_KEY.
AGENT_AI_MODE=off
GROQ_API_KEY=
